[
  {
    "name": "API - Contract",
    "matchedStatuses": ["failed"],
    "messageRegex": ".*(schema|contract|JSON|response body|request body|body should match|response should match).*"
  },
  {
    "name": "API - Authentication",
    "matchedStatuses": ["failed", "broken"],
    "messageRegex": ".*(401|Unauthorized|token|credential|login).*",
