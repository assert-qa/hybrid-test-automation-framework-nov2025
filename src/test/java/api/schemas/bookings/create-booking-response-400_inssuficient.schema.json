{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "success",
    "error"
  ],
  "properties": {
    "success": {
      "type": "boolean",
      "const": false
    },
    "error": {
      "type": "string",
      "pattern": "^Only \\d+ seat\\(s\\) available, but \\d+ requested$"
    }
  }
}